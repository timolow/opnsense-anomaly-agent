# OPNsense Anomaly Detection Agent - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# OPNsense Firewall Connection
# (used for status lookups, not event polling)
# ============================================================
OPN_HOST=192.168.1.1
OPN_PORT=6666
OPN_API_KEY=your_api_key_here
OPN_API_SECRET=your_api_secret_here
OPN_VERIFY_SSL=false

# ============================================================
# Discord Bot
# ============================================================
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# ============================================================
# Agent Configuration
# ============================================================
# Chat command HTTP server port
CHAT_PORT=8765

# ============================================================
# Syslog Listener (built-in UDP)
# Set to true to run syslog listener inside the agent container
# Set to false to read from external JSONL file (default)
# ============================================================
SYSLOG_ENABLED=false
SYSLOG_UDP_PORT=1514

# ============================================================
# vLLM Inference Server (optional - for future LLM-based analysis)
# Set VLLM_BASE_URL to enable LLM anomaly analysis
# ============================================================
VLLM_BASE_URL=
VLLM_MODEL=QuantTrio/Qwen3.6-35B-A3B-AWQ
